# Frontend Admin - Environment variables
# Copy to .env.local and set values. Vite only exposes variables prefixed with VITE_

# Required in production (optional in dev; defaults in code)
VITE_OATHKEEPER_URL=/api

# Auth and admin URLs (used for login redirect, logout, recovery links)
VITE_AUTH_URL=http://auth.ory.localhost
VITE_AUTH_UI_URL=http://auth.ory.localhost
VITE_ADMIN_URL=http://admin.ory.localhost

# API / Kratos public (optional; Oathkeeper often serves both)
VITE_KRATOS_PUBLIC_URL=/api
VITE_KRATOS_BROWSER_URL=http://auth.ory.localhost/auth

# Optional: base API URL for other endpoints
VITE_API_URL=/api

# Optional: audit log endpoint (POST JSON). If set, admin actions can be sent for audit.
# VITE_AUDIT_API_URL=https://api.example.com/admin/audit
