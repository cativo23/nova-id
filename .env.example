# Nova ID Environment Configuration Template
# Copy this file to .env for local development or .env.production for production
# NEVER commit .env or .env.production with real secrets!
#
# Generate secrets (use for every secret below; never leave placeholders in production):
#   openssl rand -base64 32

# Environment (local or production)
ENVIRONMENT=local

# Node Environment
NODE_ENV=development

# Database Configuration
POSTGRES_PASSWORD=CHANGE_ME_32_CHARS_MIN
ORY_PASSWORD=CHANGE_ME_32_CHARS_MIN
KRATOS_DB_PASSWORD=CHANGE_ME_32_CHARS_MIN
HYDRA_DB_PASSWORD=CHANGE_ME_32_CHARS_MIN
KETO_DB_PASSWORD=CHANGE_ME_32_CHARS_MIN

# Kratos Secrets
# Ory path-maps these via SCREAMING_SNAKE_CASE (dots→underscores, uppercase).
# docker-compose passes them as SECRETS_COOKIE, SECRETS_CIPHER, SECRETS_DEFAULT.
# cookie:  ≥16 chars (signs session cookies)
# cipher:  EXACTLY 32 chars (xchacha20-poly1305 data encryption)
# default: ≥16 chars (fallback signing/encryption key)
# Generate each with: openssl rand -base64 32 | tr -d '=' | cut -c1-32
KRATOS_SECRETS_COOKIE=CHANGE_ME_32_CHARS_MIN
KRATOS_SECRETS_CIPHER=CHANGE_ME_EXACTLY_32_CHARS_12345
KRATOS_SECRETS_DEFAULT=CHANGE_ME_32_CHARS_MIN

# Hydra Secrets (32+ characters; use HYDRA_SYSTEM_SECRET in all configs)
HYDRA_SYSTEM_SECRET=CHANGE_ME_32_CHARS_MIN

# API: Hydra Admin URL (server-side only; API calls Hydra Admin for login/consent accept)
# Local: use internal Docker URL. Production: use internal URL (e.g. http://hydra:4445).
# Never expose Hydra Admin to the public internet (see docs/SECURITY_CODE_REVIEW.md).
HYDRA_ADMIN_URL=http://hydra:4445

# API: Kratos Admin URL (server-side only; BFF calls Kratos Admin for identity CRUD).
# Internal Docker network only — never expose Kratos Admin to the public internet.
KRATOS_ADMIN_URL=http://kratos:4434

# API: Keto Read URL (server-side only; BFF runs permission checks here).
# Internal Docker network only.
KETO_READ_URL=http://keto:4466

# API: JWT validation (Oathkeeper id_token mutator)
# OAUTH_ISSUER MUST match the id_token issuer_url in config/oathkeeper/oathkeeper.${ENVIRONMENT}.yml.
# Production: OAUTH_ISSUER=https://api.cativo.dev/  (must equal oathkeeper.production.yml id_token issuer_url)
OAUTH_ISSUER=http://api.local/
# OAUTH_JWKS_URL: REQUIRED. Oathkeeper's JWKS API endpoint. Oathkeeper mints an
# RS256 id_token (Bearer JWT) for authenticated requests and publishes its public
# key here; the API verifies every token against this endpoint (RS256 + issuer).
# No PEM needed — the key is fetched and cached from the JWKS. No built-in fallback.
OAUTH_JWKS_URL=http://oathkeeper:4456/.well-known/jwks.json

# CORS: comma-separated allowlist of browser origins. Empty = deny all cross-origin.
CORS_ALLOWED_ORIGINS=http://auth.ory.localhost,http://admin.ory.localhost,http://app.ory.localhost

# URLs - Local Development
API_URL=http://api.local
KRATOS_BROWSER_URL=http://auth.local
ADMIN_URL=http://admin.local

# URLs - Production (uncomment and set for production)
# API_URL=https://api.cativo.dev
# KRATOS_BROWSER_URL=https://auth.cativo.dev
# ADMIN_URL=https://admin.cativo.dev

# SMTP Configuration
# Local: Mailpit (no auth, no TLS)
SMTP_CONNECTION_URI=smtp://mailpit:1025/?disable_starttls=true
SMTP_FROM_ADDRESS=noreply@cativo.dev

# Production SMTP (example - adjust for your provider)
# SMTP_CONNECTION_URI=smtps://user:pass@smtp.example.com:465
# SMTP_FROM_ADDRESS=noreply@cativo.dev
