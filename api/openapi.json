      "post": {
        "operationId": "acceptHydraLogin",
        "summary": "Accept a Hydra login challenge for the signed-in user",
        "parameters": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/AcceptHydraLoginDto"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HydraRedirectResponseDto"
                }
              }
            }
          }
        },
        "tags": [
          "auth"
        ]
      }
    },
    "/v1/hydra-accept-consent": {
      "post": {
        "operationId": "acceptHydraConsent",
