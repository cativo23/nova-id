        "parameters": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/AcceptHydraConsentDto"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HydraRedirectResponseDto"
                }
              }
            }
          }
        },
        "tags": [
          "auth"
        ]
      }
    },
    "/v1/admin/users": {
      "get": {
        "operationId": "AdminUsersController_list",
        "summary": "List all platform users (cursor-paginated)",
        "parameters": [
          {
            "name": "pageSize",
            "required": false,
            "in": "query",
            "schema": {
              "minimum": 1,
              "maximum": 500,
              "default": 100,
              "type": "number"
            }
          },
          {
            "name": "pageToken",
            "required": false,
            "in": "query",
            "description": "Opaque Kratos pagination token",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Page of users + optional next-page cursor",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PaginatedUsersDto"
                }
              }
            }
          },
          "401": {
            "description": "Missing or invalid Bearer id_token"
          },
          "403": {
            "description": "Caller lacks Platform:nova#manage_users in Keto"
          }
        },
        "tags": [
          "admin"
        ],
        "security": [
          {
            "oathkeeper-id-token": []
          }
        ]
      },
      "post": {
        "operationId": "AdminUsersController_create",
        "summary": "Create a new platform user identity",
        "parameters": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateUserDto"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Identity created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/UserResponseDto"
                }
              }
            }
          },
          "401": {
            "description": "Missing or invalid Bearer id_token"
          },
          "403": {
            "description": "Caller lacks Platform:nova#manage_users in Keto"
          },
          "409": {
            "description": "Email already registered"
          },
          "422": {
            "description": "Validation failed"
          }
        },
        "tags": [
          "admin"
        ],
        "security": [
          {
            "oathkeeper-id-token": []
          }
        ]
      }
    },
    "/v1/admin/users/{id}": {
      "get": {
        "operationId": "AdminUsersController_get",
        "summary": "Get a single user by Kratos identity id",
        "parameters": [
          {
            "name": "id",
            "required": true,
            "in": "path",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/UserResponseDto"
                }
              }
            }
          },
          "401": {
            "description": "Missing or invalid Bearer id_token"
          },
          "403": {
            "description": "Caller lacks Platform:nova#manage_users in Keto"
          },
          "404": {
            "description": "Identity not found"
          }
        },
        "tags": [
          "admin"
        ],
        "security": [
          {
            "oathkeeper-id-token": []
          }
        ]
      },
      "delete": {
        "operationId": "AdminUsersController_remove",
        "summary": "Delete a user identity permanently",
        "parameters": [
          {
            "name": "id",
            "required": true,
            "in": "path",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "204": {
            "description": "Identity deleted"
          },
          "401": {
            "description": "Missing or invalid Bearer id_token"
          },
          "403": {
            "description": "Caller lacks Platform:nova#manage_users in Keto"
          },
          "404": {
            "description": "Identity not found"
          }
        },
        "tags": [
          "admin"
        ],
        "security": [
          {
            "oathkeeper-id-token": []
          }
        ]
      },
      "patch": {
        "operationId": "AdminUsersController_update",
        "summary": "Partially update user traits / role",
        "parameters": [
          {
            "name": "id",
            "required": true,
            "in": "path",
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/UpdateUserDto"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/UserResponseDto"
                }
              }
            }
          },
          "401": {
            "description": "Missing or invalid Bearer id_token"
          },
          "403": {
            "description": "Caller lacks Platform:nova#manage_users in Keto"
          },
          "404": {
            "description": "Identity not found"
          }
        },
        "tags": [
          "admin"
        ],
        "security": [
          {
            "oathkeeper-id-token": []
          }
        ]
      }
    },
    "/v1/admin/users/{id}/state": {
      "patch": {
        "operationId": "AdminUsersController_setState",
        "summary": "Activate or deactivate a user identity",
        "parameters": [
          {
            "name": "id",
            "required": true,
            "in": "path",
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/SetUserStateDto"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/UserResponseDto"
                }
              }
            }
          },
          "401": {
            "description": "Missing or invalid Bearer id_token"
          },
          "403": {
            "description": "Caller lacks Platform:nova#manage_users in Keto"
          },
          "404": {
            "description": "Identity not found"
          }
        },
        "tags": [
          "admin"
        ],
        "security": [
          {
            "oathkeeper-id-token": []
          }
        ]
      }
    },
    "/v1/admin/users/{id}/recovery-link": {
      "post": {
        "operationId": "AdminUsersController_recoveryLink",
        "summary": "Generate a recovery link for a user",
        "parameters": [
          {
            "name": "id",
            "required": true,
            "in": "path",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "201": {
            "description": "Recovery link generated",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/RecoveryLinkResponseDto"
                }
              }
            }
          },
          "401": {
            "description": "Missing or invalid Bearer id_token"
          },
          "403": {
            "description": "Caller lacks Platform:nova#manage_users in Keto"
          },
          "404": {
            "description": "Identity not found"
          }
        },
        "tags": [
          "admin"
        ],
        "security": [
          {
            "oathkeeper-id-token": []
