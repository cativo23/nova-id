{
  "name": "@nova-id/api-client",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "openapi:copy": "node -e \"require('fs').copyFileSync('../../api/openapi.json','openapi.json')\"",
    "generate": "pnpm run openapi:copy && orval --config ./orval.config.ts",
    "typecheck": "vue-tsc --noEmit -p tsconfig.json"
  },
  "peerDependencies": {
    "@tanstack/vue-query": "^5.100.9",
    "axios": "^1.7.0",
    "vue": "^3.4.21"
  },
  "devDependencies": {
    "orval": "8.17.0",
    "typescript": "^5.4.0",
    "vue-tsc": "^2.0.0"
  }
}
