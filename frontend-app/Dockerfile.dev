# Development Dockerfile - Runs Vite dev server
FROM node:18-alpine

WORKDIR /app

# Build arguments for environment variables (optional, .env.local takes precedence)
# These are only used if .env.local doesn't exist
ARG VITE_KRATOS_PUBLIC_URL=/api
ARG VITE_OATHKEEPER_URL=/api
# Don't set ENV here - let Vite read from .env.local file instead
# ENV variables would override .env.local, which we don't want
# Proxy /api to Oathkeeper in Docker (vite.config.js uses this; avoids IPv6 localhost)
ENV API_PROXY_TARGET=http://oathkeeper:4455

# Copy package files
COPY package*.json ./

# Install dependencies
RUN npm install

# Copy source code (will be overridden by volume mount in docker-compose)
COPY . .

# Expose Vite dev server port
EXPOSE 5175

# Run Vite dev server with host binding for Docker
CMD ["npm", "run", "dev", "--", "--host", "0.0.0.0", "--port", "5175"]
