<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Verification attempt</title>
</head>
<body style="margin:0; padding:0; background-color:#1a1b26; font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,Oxygen,Ubuntu,sans-serif; color:#c0caf5; font-size:15px; line-height:1.5; -webkit-font-smoothing:antialiased;">
  <table role="presentation" width="100%" cellspacing="0" cellpadding="0" style="background-color:#1a1b26;">
    <tr>
      <td align="center" style="padding:32px 16px;">
        <table role="presentation" cellspacing="0" cellpadding="0" style="max-width:440px; width:100%; background-color:#16161e; border:1px solid rgba(125,207,255,0.2); border-radius:12px;">
          <tr>
            <td style="padding:32px 24px;">
              <p style="margin:0 0 24px; font-size:18px; font-weight:600; letter-spacing:2px; color:#7dcfff;">NOVA_ID</p>
              <h1 style="margin:0 0 8px; font-size:20px; font-weight:600; color:#c0caf5;">Verification attempt</h1>
              <p style="margin:0 0 12px; font-size:14px; color:rgba(192,202,245,0.65);">Someone asked to verify this email address, but we could not find an account for it.</p>
              <p style="margin:0 0 8px; font-size:14px; color:rgba(192,202,245,0.65);">If this was you, check if you signed up using a different address.</p>
              <p style="margin:0; font-size:14px; color:rgba(192,202,245,0.5);">If this was not you, please ignore this email.</p>
            </td>
          </tr>
        </table>
      </td>
    </tr>
  </table>
</body>
</html>
