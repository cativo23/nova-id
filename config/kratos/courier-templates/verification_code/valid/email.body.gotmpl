<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Verify your email</title>
</head>
<body style="margin:0; padding:0; background-color:#1a1b26; font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,Oxygen,Ubuntu,sans-serif; color:#c0caf5; font-size:15px; line-height:1.5; -webkit-font-smoothing:antialiased;">
  <table role="presentation" width="100%" cellspacing="0" cellpadding="0" style="background-color:#1a1b26;">
    <tr>
      <td align="center" style="padding:32px 16px;">
        <table role="presentation" cellspacing="0" cellpadding="0" style="max-width:440px; width:100%; background-color:#16161e; border:1px solid rgba(125,207,255,0.2); border-radius:12px;">
          <tr>
            <td style="padding:32px 24px;">
              <p style="margin:0 0 24px; font-size:18px; font-weight:600; letter-spacing:2px; color:#7dcfff;">NOVA_ID</p>
              <h1 style="margin:0 0 8px; font-size:20px; font-weight:600; color:#c0caf5;">Verify your email</h1>
              <p style="margin:0 0 20px; font-size:14px; color:rgba(192,202,245,0.65);">Verify your account with the following code:</p>
              <p style="margin:0 0 16px; padding:14px 18px; background:rgba(125,207,255,0.1); border:1px solid rgba(125,207,255,0.25); border-radius:8px; font-size:20px; font-weight:700; color:#7dcfff; letter-spacing:3px; font-family:'Courier New',monospace;">{{ .VerificationCode }}</p>
              <p style="margin:0 0 20px; font-size:14px; color:rgba(192,202,245,0.65);">Or click: <a href="{{ .VerificationURL }}" style="color:#7dcfff; text-decoration:none;">{{ .VerificationURL }}</a></p>
              <p style="margin:0 0 24px; font-size:14px; color:rgba(192,202,245,0.65);">If this was not you, do nothing. This code and link expire in {{ .ExpiresInMinutes }} minutes.</p>
              <p style="margin:0; font-size:13px; color:rgba(192,202,245,0.5);">Need help? Contact <a href="mailto:support@cativo.dev" style="color:#7dcfff; text-decoration:none;">support@cativo.dev</a>.</p>
            </td>
          </tr>
        </table>
      </td>
    </tr>
  </table>
</body>
</html>
