  {
    "id": "public-api",
    "upstream": {
      "preserve_host": true,
      "strip_path": "/api",
      "url": "http://api:8080"
    },
    "match": {
      "url": "<(http|https)://(api\\.cativo\\.dev|oathkeeper(:[0-9]+)?)/api/(health|public)>",
      "methods": ["GET", "OPTIONS"]
    },
    "authenticators": [
      {
        "handler": "noop"
      }
    ],
    "authorizer": {
      "handler": "allow"
    },
    "mutators": [
      {
        "handler": "noop"
      }
    ]
  },
  {
    "id": "protected-api",
    "upstream": {
      "preserve_host": true,
      "strip_path": "/api",
      "url": "http://api:8080"
    },
    "match": {
      "url": "<(http|https)://(api\\.cativo\\.dev|oathkeeper(:[0-9]+)?)/api/(protected|user-demo|admin-demo|me|data|logs|nova-id-session)(/.*)?>",
      "methods": ["GET", "POST", "PUT", "DELETE", "PATCH", "OPTIONS"]
    },
    "authenticators": [
      {
        "handler": "cookie_session",
        "config": {
          "check_session_url": "http://kratos:4433/sessions/whoami",
          "preserve_path": true,
          "extra_from": "@this",
          "subject_from": "identity.id"
        }
      },
      {
        "handler": "oauth2_introspection"
      }
    ],
    "authorizer": {
      "handler": "allow"
    },
    "mutators": [
      {
        "handler": "header",
        "config": {
          "headers": {
            "X-User-ID": "{{ print .Subject }}",
            "X-User-Email": "{{ if .Extra.identity }}{{ .Extra.identity.traits.email }}{{ else }}{{ if index .Extra \"ext\" }}{{ index (index .Extra \"ext\") \"email\" }}{{ else }}{{ if index .Extra \"session\" }}{{ index (index .Extra \"session\") \"email\" }}{{ else }}{{ index .Extra \"email\" }}{{ end }}{{ end }}{{ end }}",
            "X-User-Name": "{{ if .Extra.identity }}{{ .Extra.identity.traits.full_name }}{{ else }}{{ if index .Extra \"ext\" }}{{ index (index .Extra \"ext\") \"name\" }}{{ else }}{{ if index .Extra \"session\" }}{{ index (index .Extra \"session\") \"name\" }}{{ else }}{{ index .Extra \"name\" }}{{ end }}{{ end }}{{ end }}",
            "X-User-Role": "{{ if .Extra.identity }}{{ .Extra.identity.metadata_public.role }}{{ else }}{{ if index .Extra \"ext\" }}{{ index (index .Extra \"ext\") \"role\" }}{{ else }}{{ if index .Extra \"session\" }}{{ index (index .Extra \"session\") \"role\" }}{{ else }}{{ index .Extra \"role\" }}{{ end }}{{ end }}{{ end }}",
            "X-Gateway-Auth": "{{ getenv \"GATEWAY_SHARED_SECRET\" }}"
          }
        }
      }
    ]
  },
