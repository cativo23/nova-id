    "id": "kratos-public",
    "upstream": {
      "preserve_host": false,
      "url": "http://kratos:4433"
    },
    "match": {
      "url": "<(http|https)://(api\\.cativo\\.dev|oathkeeper(:[0-9]+)?)/(self-service|sessions|health|schemas).*>",
      "methods": ["GET", "POST", "PUT", "DELETE", "PATCH", "OPTIONS"]
    },
    "authenticators": [
      {
        "handler": "noop"
      }
    ],
