  {
    "id": "oathkeeper-health",
    "upstream": {
      "preserve_host": false,
      "url": "http://oathkeeper:4456"
    },
    "match": {
      "url": "<(http|https)://api\\.cativo\\.dev/health/.*>",
      "methods": ["GET"]
    },
    "authenticators": [
      {
        "handler": "noop"
      }
    ],
    "authorizer": {
      "handler": "allow"
    },
    "mutators": [
      {
        "handler": "noop"
      }
    ]
  },
