    "id": "kratos-admin",
    "upstream": {
      "preserve_host": false,
      "url": "http://kratos:4434"
    },
    "match": {
      "url": "<(http|https)://(api\\.cativo\\.dev|oathkeeper(:[0-9]+)?)/admin/(identities.*|sessions.*|recovery.*|health|version|schemas.*)>",
      "methods": ["GET", "POST", "PUT", "DELETE", "PATCH"]
    },
    "authenticators": [
      {
        "handler": "cookie_session"
      }
    ],
    "authorizer": {
      "handler": "remote_json",
      "config": {
        "remote": "http://keto:4466/relation-tuples/check",
        "payload": "{\"namespace\":\"users\",\"object\":\"management\",\"relation\":\"view_users\",\"subject_id\":\"user:{{ print .Subject }}\"}",
        "forward_response_headers_to_upstream": ["Content-Type"]
      }
    },
    "mutators": [
      {
        "handler": "header",
        "config": {
          "headers": {
            "X-User-ID": "{{ print .Subject }}",
            "X-User-Email": "{{ print .Extra.identity.traits.email }}",
            "X-Gateway-Auth": "{{ getenv \"GATEWAY_SHARED_SECRET\" }}"
          }
        }
      }
    ]
  },
