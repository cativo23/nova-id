    "upstream": {
      "preserve_host": true,
      "strip_path": "/api",
      "url": "http://api:8080"
    },
    "match": {
      "url": "<(http|https)://(api\\.ory\\.localhost|admin\\.ory\\.localhost|auth\\.ory\\.localhost|app\\.ory\\.localhost|localhost(:[0-9]+)?|oathkeeper(:[0-9]+)?)/api/(protected|user-demo|admin-demo|me|data|logs|nova-id-session|hydra-accept-login|hydra-accept-consent)(/.*)?>",
      "methods": ["GET", "POST", "PUT", "DELETE", "PATCH", "OPTIONS"]
    },
    "authenticators": [
      {
        "handler": "cookie_session",
        "config": {
          "check_session_url": "http://kratos:4433/sessions/whoami",
          "preserve_path": true,
          "extra_from": "@this",
          "subject_from": "identity.id"
        }
      },
      {
        "handler": "oauth2_introspection"
      }
    ],
    "authorizer": {
      "handler": "allow"
    },
